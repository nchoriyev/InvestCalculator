# InvestCalc DSS — environment shabloni
# Ushbu faylni `.env` nomi bilan nusxalang va qiymatlarini to'ldiring.
# `.env` faylini HECH QACHON git ga commit qilmang.

# --- Asosiy ---
DEBUG=False
# Yaratish: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=replace-me-with-a-strong-random-string
# Vergul bilan ajratilgan domenlar ro'yxati
ALLOWED_HOSTS=investcalc.uz,www.investcalc.uz

# --- Ma'lumotlar bazasi ---
# Local/dev uchun SQLite: USE_SQLITE=True (qolgan POSTGRES_* e'tibor qilinmaydi)
USE_SQLITE=False
POSTGRES_DB=investcalc
POSTGRES_USER=investcalc
POSTGRES_PASSWORD=change-me-strong-password
# Host: localda 127.0.0.1, Docker da: db (service nomi)
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# --- Ixtiyoriy: Sentry ---
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
